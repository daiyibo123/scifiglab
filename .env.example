# SciFigLab 环境变量配置

APP_NAME=SciFigLab
APP_ENV=development
SECRET_KEY=change-me-in-production
GITHUB_REPO_URL=https://github.com/daiyibo123/scifiglab.git

# SMTP / Resend (可选)
# Resend SMTP 示例：
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=你的 Resend API Key
# SMTP_FROM=SciFigLab <no-reply@你的已验证域名>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# 邮箱验证码
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_INTERVAL_SECONDS=60
EMAIL_CODE_MAX_PER_HOUR=5

# 上传限制
UPLOAD_MAX_SIZE_MB=50
